document.addEventListener('DOMContentLoaded',function(){const filterTabs=document.querySelectorAll('.directory-filter .filter-tab');const directoryCards=document.querySelectorAll('.directory-card');if(filterTabs.length===0||directoryCards.length===0){return}
filterTabs.forEach(function(tab){tab.addEventListener('click',function(){const selectedRegion=this.getAttribute('data-region');filterTabs.forEach(function(t){t.classList.remove('active')});this.classList.add('active');directoryCards.forEach(function(card){const cardRegion=card.getAttribute('data-region');if(selectedRegion==='all'||cardRegion===selectedRegion){card.style.display='';card.style.opacity='0';setTimeout(function(){card.style.transition='opacity 0.3s ease-in-out';card.style.opacity='1'},10)}else{card.style.display='none'}})})})})